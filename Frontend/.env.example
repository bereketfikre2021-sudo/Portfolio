# Google Analytics 4 - get your Measurement ID from https://analytics.google.com/
# Create a GA4 property → Data Streams → Web → copy the Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend API URL — change to localhost:5000/api for local development
VITE_API_URL=https://bereket-fikre-backend.onrender.com/api

# Legacy CRA name still supported by vite.config.js define shim:
# REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
