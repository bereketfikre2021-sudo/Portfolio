# Google Analytics 4 - get your Measurement ID from https://analytics.google.com/
# Create a GA4 property → Data Streams → Web → copy the Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

